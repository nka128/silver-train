#!/usr/bin/env bash

set -euo pipefail

# -----------------------------------------------------------------------------
# No early-exit / version stamp (unlike Universal Blue dx image group helpers).
#
# Wheel membership can change after first boot (e.g. new admins). Exiting early
# after a one-time stamp would skip usermod for users added to wheel later.
#
# Safe to run every boot: ensure_group uses groupadd when the group is missing
# (NordVPN docs; the RPM does not ship a static line in /usr/lib/group). usermod -aG
# only appends supplementary groups and does not duplicate membership when the user
# is already in nordvpn.
# -----------------------------------------------------------------------------

# # SCRIPT VERSION — disabled; see comment block above
# GROUP_SETUP_VER=1
# GROUP_SETUP_VER_FILE="/etc/ublue/nordvpn-group"
# GROUP_SETUP_VER_RAN=""
# if [[ -f "$GROUP_SETUP_VER_FILE" ]]; then
#   GROUP_SETUP_VER_RAN=$(cat "$GROUP_SETUP_VER_FILE")
# fi

# make the directory if it doesn't exist
mkdir -p /etc/ublue

# # Run script if updated
# if [[ -f "$GROUP_SETUP_VER_FILE" && "$GROUP_SETUP_VER" = "$GROUP_SETUP_VER_RAN" ]]; then
#   echo "NordVPN group setup has already run. Exiting..."
#   exit 0
# fi

ensure_group() {
  local group_name="$1"
  if getent group "$group_name" &>/dev/null; then
    return 0
  fi
  echo "Creating group $group_name"
  groupadd "$group_name"
}

ensure_group nordvpn

wheelarray=($(getent group wheel | cut -d ":" -f 4 | tr ',' '\n'))
for user in "${wheelarray[@]}"; do
  [[ -n "$user" ]] || continue
  usermod -aG nordvpn "$user"
done

# # Prevent future executions (tied to disabled GROUP_SETUP_VER stamp)
# echo "Writing state file"
# echo "$GROUP_SETUP_VER" >"$GROUP_SETUP_VER_FILE"
